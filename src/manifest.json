{
    "manifest_version": 3,
    "name": "Flavortown Devlog Exporter",
    "version": "1.0",

    "description": "Export Flavortown project devlogs.",
    
    "permissions": [
        "downloads",
        "declarativeNetRequest",
        "declarativeNetRequestWithHostAccess"
    ],

    "icons": {
        "48": "icons/icon-48.ico"
    },

    "content_scripts": [
        {
            "matches": ["*://flavortown.hackclub.com/projects/*"],
            "js": [
                "module/turndown.js",
                "module/jszip.js",
                "module/FileSaver.js",
                "devlog_exporter.js"
            ]
        }
    ],

    "host_permissions": [
        "https://flavortown.hackclub.com/*"
    ],
    "declarative_net_request": {
        "rule_resources": [
            {
                "id": "flavortown_header",
                "enabled": true,
                "path": "rules.json"
            }
        ]
    }
}