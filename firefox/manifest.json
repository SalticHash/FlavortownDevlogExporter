{
    "manifest_version": 2,
    "name": "Flavortown Devlog Exporter",
    "version": "1.0",

    "description": "Export Flavortown project devlogs.",

    "icons": {
        "48": "icons/icon-48.ico"
    },

    "content_scripts": [
        {
            "matches": ["*://flavortown.hackclub.com/projects/*"],
            "js": ["turndown.js", "devlog_exporter.js"]
        }
    ]
}