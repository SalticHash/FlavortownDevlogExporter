{
    "manifest_version": 2,
    "name": "Borderify",
    "version": "1.0",

    "description": "Adds a red border to all webpages matching mozilla.org.",

    "icons": {
        "48": "icons/icon-48.ico"
    },

    "content_scripts": [
        {
            "matches": ["*://flavortown.hackclub.com/projects/*"],
            "js": ["devlog_exporter.js"]
        }
    ]
}